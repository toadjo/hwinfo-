    <tags>obfuscar,obfuscation</tags>
    <packageTypes>
      <packageType name="DotnetTool" />
    </packageTypes>
    <repository type="git" url="https://github.com/obfuscar/obfuscar" branch="master" commit="e1d8b6ce072009cf9e40ff2ddd0c6216a9722da7" />
  </metadata>
</package>